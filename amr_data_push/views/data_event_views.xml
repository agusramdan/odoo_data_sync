<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_internal_data_event_form" model="ir.ui.view">
        <field name="name">internal.data.event.form</field>
        <field name="model">internal.data.event</field>
        <field name="inherit_id" ref="amr_data_event.view_internal_data_event_form" />
        <field name="arch" type="xml">
            <header>
                <button name="action_prepare_payload"
                                type="object"
                                string="Prepare Payload"
                                class="btn-primary"
                />
                <button name="action_dispatch_audiences"
                                type="object"
                                string="Dispatch Audience"
                                class="btn-primary"
                />
            </header>

            <field name="event_datetime" position="after">
                <field name="audiences" />
            </field>
            <notebook position="inside">
                <page string="Payload">
                    <field name="push_payload"/>
                </page>
            </notebook>

        </field>
    </record>

</odoo>
