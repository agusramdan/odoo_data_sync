<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.wa</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="amr_resource.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='amr_data_sync_setting_box']" position="inside">
                <div class="content-group">
                    <div class="row mt16">
                        <label for="amr_date_update_option" class="col-lg-3 o_light_label"/>
                        <field name="amr_date_update_option"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
