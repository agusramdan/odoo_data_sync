<odoo>
    <data>

        <record id="external_data_sync_cron_filter" model="ir.ui.view">
            <field name="name">external.data.sync.cron.search</field>
            <field name="model">external.data.sync.cron</field>
            <field name="arch" type="xml">
                <search string="External Data">
                    <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_external_model" string="Model" domain="[]" context="{'group_by': 'external_model'}"/>
                        <filter name="group_application_name" string="Application Name" domain="[]" context="{'group_by': 'external_app_name'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="external_data_sync_cron_form" model="ir.ui.view">
            <field name="name">external.data.sync.cron.form</field>
            <field name="model">external.data.sync.cron</field>
            <field name="priority" eval="99" />
            <field name="arch" type="xml">
                <form string="sync">
                    <header>
                        <button name="action_sync_now" type="object" string="Sync Data From Server" class="oe_highlight" />
<!--                        <field name="state" readonly="1" widget="statusbar" statusbar_visible="progress,done"/>-->
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box"/>
                        <widget name="web_ribbon" title="Archived" bg_color="bg-danger" attrs="{'invisible': [('active', '=', True)]}"/>
                        <div class="oe_title">
                            <field name="active" invisible="1"/>
                        </div>
                        <group>
                            <group>
                                <field name="server_sync_id"/>
                                <field name="external_app_name"/>
                            </group>
                            <group>
                                <field name="next_sync_datetime" />
                                <field name="last_sync_datetime"/>
                            </group>
                        </group>

                    </sheet>
                </form>
            </field>
        </record>

        <record id="external_data_sync_cron_tree" model="ir.ui.view">
            <field name="name">external.data.sync.cron.tree</field>
            <field name="model">external.data.sync.cron</field>
            <field name="priority" eval="99" />
            <field name="arch" type="xml">
                <tree >
                    <field name="server_sync_id"/>
                    <field name="external_app_name"/>
                    <field name="external_model"/>
                    <field name="internal_model"/>

                    <field name="next_sync_datetime"/>
                    <field name="last_sync_datetime"/>
                </tree>
            </field>
        </record>

        <record model="ir.actions.act_window" id="external_data_sync_cron_action">
            <field name="name">Data Sync Cron</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">external.data.sync.cron</field>
            <field name="view_mode">tree,form</field>
            <field name="domain">[]</field>
        </record>


    </data>
</odoo>
